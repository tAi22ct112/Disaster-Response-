{
  "name": "disasterresponsenetwork",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "apk:auto": "powershell -ExecutionPolicy Bypass -File scripts/build-apk-auto.ps1",
    "apk:auto:named": "powershell -ExecutionPolicy Bypass -File scripts/build-apk-auto.ps1 -TunnelMode named",
    "apk:auto:quick": "powershell -ExecutionPolicy Bypass -File scripts/build-apk-auto.ps1 -TunnelMode quick",
    "apk:auto:no-build": "powershell -ExecutionPolicy Bypass -File scripts/build-apk-auto.ps1 -SkipBuild",
    "apk:auto:named:no-build": "powershell -ExecutionPolicy Bypass -File scripts/build-apk-auto.ps1 -TunnelMode named -SkipBuild",
    "tunnel:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-auto-tunnel.ps1",
    "build:apk": "npx eas build -p android --profile preview",
    "build:aab": "npx eas build -p android --profile production",
    "submit:android": "npx eas submit -p android"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/drawer": "^7.9.4",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/stack": "^7.8.4",
    "expo": "~55.0.4",
    "expo-av": "^16.0.8",
    "expo-dev-client": "^55.0.11",
    "expo-haptics": "~55.0.8",
    "expo-image-picker": "^55.0.11",
    "expo-linear-gradient": "~55.0.8",
    "expo-location": "~55.1.2",
    "expo-notifications": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.9",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-maps": "1.26.20",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.3.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
